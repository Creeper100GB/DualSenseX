<UserControl x:Class="DSX.WPF.Navigation.NavigationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:nav="clr-namespace:DSX.WPF.Navigation"
             xmlns:converters="clr-namespace:DSX.WPF.Converters"
             mc:Ignorable="d"
             d:DesignWidth="240" d:DesignHeight="800">

    <UserControl.Resources>
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Background="{StaticResource SidebarBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Logo + Version -->
        <StackPanel Grid.Row="0" Margin="16,20,16,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Border Width="32" Height="32"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="6"
                        Margin="0,0,10,0">
                    <TextBlock Text="D"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="Black"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DualSenseX"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="v3.1.5.3"
                               FontSize="10"
                               Foreground="{StaticResource TextMuted}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Profile Selector -->
        <Border Grid.Row="1"
                Background="{StaticResource InputBackground}"
                BorderBrush="{StaticResource InputBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                Margin="12,4,12,12"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Default Profile"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <Path Grid.Column="1"
                      Data="M0,0 L4,4 8,0"
                      Stroke="{StaticResource TextMuted}"
                      StrokeThickness="1.5"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Navigation Items -->
        <ScrollViewer Grid.Row="2"
                      Style="{StaticResource DSXScrollViewer}"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,4">
            <StackPanel Margin="4,0"
                        PreviewMouseLeftButtonUp="OnNavMouseUp">
                <RadioButton x:Name="NavHome"
                             Content="Home"
                             Tag="&#xE80F;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />
                <RadioButton x:Name="NavMyControllers"
                             Content="My Controllers"
                             Tag="&#xE960;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />
                <RadioButton x:Name="NavControllerMapping"
                             Content="Controller Mapping"
                             Tag="&#xE943;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />
                <RadioButton x:Name="NavAdaptiveTriggers"
                             Content="Adaptive Triggers"
                             Tag="&#xE963;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />
                <RadioButton x:Name="NavLEDLighting"
                             Content="LED / Lighting"
                             Tag="&#xE768;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />
                <RadioButton x:Name="NavHapticsRumble"
                             Content="Haptics / Rumble"
                             Tag="&#xE95F;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />
                <RadioButton x:Name="NavVirtualDevice"
                             Content="Virtual Device"
                             Tag="&#xE912;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />

                <Separator Background="{StaticResource BorderBrush}"
                           Margin="12,8" />

                <RadioButton x:Name="NavInstalledGames"
                             Content="Installed Games"
                             Tag="&#xE990;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />
                <RadioButton x:Name="NavMods"
                             Content="Mods"
                             Tag="&#xE902;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />
                <RadioButton x:Name="NavHidHide"
                             Content="HidHide"
                             Tag="&#xE72E;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />

                <Separator Background="{StaticResource BorderBrush}"
                           Margin="12,8" />

                <RadioButton x:Name="NavSettings"
                             Content="Settings"
                             Tag="&#xE713;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />
                <RadioButton x:Name="NavHelpCenter"
                             Content="Help Center"
                             Tag="&#xE897;"
                             GroupName="Nav"
                             Style="{StaticResource NavigationButton}"
                             Checked="OnNavChecked" />
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Section -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="ConnectionIndicator"
                         Grid.Column="0"
                         Width="8" Height="8"
                         Fill="{StaticResource ErrorBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           x:Name="ConnectionStatusText"
                           Text="No Controller"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           x:Name="BatteryText"
                           Text=""
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
