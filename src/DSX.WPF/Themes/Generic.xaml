<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:DSX.WPF.Controls">

    <Style TargetType="{x:Type controls:ToggleSwitch}">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToggleSwitch}">
                    <Border x:Name="PART_Root"
                            Background="Transparent"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <Border x:Name="PART_Track"
                                Background="{Binding UncheckedBackground, RelativeSource={RelativeSource TemplatedParent}}"
                                CornerRadius="12"
                                Width="40"
                                Height="22"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                            <Border x:Name="PART_Thumb"
                                    Background="{Binding ThumbBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Margin="2,0,0,0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
