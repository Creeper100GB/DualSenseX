<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryBackgroundColor">#000000</Color>
    <Color x:Key="SecondaryBackgroundColor">#111111</Color>
    <Color x:Key="CardBackgroundColor">#1A1A1A</Color>
    <Color x:Key="SidebarBackgroundColor">#0A0A0A</Color>

    <Color x:Key="AccentColor">#00D4AA</Color>
    <Color x:Key="AccentHoverColor">#00F5C4</Color>
    <Color x:Key="AccentPressedColor">#00B894</Color>

    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#AAAAAA</Color>
    <Color x:Key="TextMutedColor">#666666</Color>

    <Color x:Key="BorderColor">#333333</Color>

    <Color x:Key="NeonBlueColor">#00B4D8</Color>
    <Color x:Key="NeonPurpleColor">#B537F2</Color>
    <Color x:Key="NeonPinkColor">#FF006E</Color>
    <Color x:Key="NeonGreenColor">#00D4AA</Color>

    <Color x:Key="SuccessColor">#00D4AA</Color>
    <Color x:Key="WarningColor">#FFB800</Color>
    <Color x:Key="ErrorColor">#FF3333</Color>

    <Color x:Key="SliderTrackColor">#333333</Color>
    <Color x:Key="SliderThumbColor">#00D4AA</Color>
    <Color x:Key="ToggleOnColor">#00D4AA</Color>
    <Color x:Key="ToggleOffColor">#555555</Color>

    <SolidColorBrush x:Key="PrimaryBackground" Color="{StaticResource PrimaryBackgroundColor}" />
    <SolidColorBrush x:Key="SecondaryBackground" Color="{StaticResource SecondaryBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackground" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBackground" Color="{StaticResource SidebarBackgroundColor}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />

    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource TextMutedColor}" />

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />

    <SolidColorBrush x:Key="NeonBlue" Color="{StaticResource NeonBlueColor}" />
    <SolidColorBrush x:Key="NeonPurple" Color="{StaticResource NeonPurpleColor}" />
    <SolidColorBrush x:Key="NeonPink" Color="{StaticResource NeonPinkColor}" />
    <SolidColorBrush x:Key="NeonGreen" Color="{StaticResource NeonGreenColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />

    <SolidColorBrush x:Key="SliderTrackBrush" Color="{StaticResource SliderTrackColor}" />
    <SolidColorBrush x:Key="SliderThumbBrush" Color="{StaticResource SliderThumbColor}" />
    <SolidColorBrush x:Key="ToggleOnBrush" Color="{StaticResource ToggleOnColor}" />
    <SolidColorBrush x:Key="ToggleOffBrush" Color="{StaticResource ToggleOffColor}" />

    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent" />
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#15FFFFFF" />
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="#08FFFFFF" />
    <SolidColorBrush x:Key="SelectedOverlayBrush" Color="#1000D4AA" />

    <SolidColorBrush x:Key="CardHoverBackground" Color="#222222" />
    <SolidColorBrush x:Key="InputBackground" Color="#0D0D0D" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#2A2A2A" />

    <CornerRadius x:Key="DefaultCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="SmallCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="LargeCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="RoundCornerRadius">999</CornerRadius>

    <Thickness x:Key="DefaultPadding">16</Thickness>
    <Thickness x:Key="SmallPadding">10</Thickness>
    <Thickness x:Key="LargePadding">20</Thickness>
    <Thickness x:Key="DefaultMargin">8</Thickness>
    <Thickness x:Key="SmallMargin">6</Thickness>
    <Thickness x:Key="LargeMargin">20</Thickness>

    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="DefaultFontSize">13</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="SmallFontSize">11</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="MediumFontSize">14</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="LargeFontSize">16</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="TitleFontSize">20</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="SubtitleFontSize">18</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="HeaderFontSize">24</sys:Double>

    <FontFamily x:Key="DefaultFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="IconFontFamily">Segoe MDL2 Assets</FontFamily>

    <Duration x:Key="FastAnimationDuration">0:0:0.15</Duration>
    <Duration x:Key="NormalAnimationDuration">0:0:0.25</Duration>

</ResourceDictionary>
