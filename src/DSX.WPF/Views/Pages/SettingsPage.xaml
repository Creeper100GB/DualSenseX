<UserControl x:Class="DSX.WPF.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DSX.WPF.Controls"
             xmlns:converters="clr-namespace:DSX.WPF.Converters"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="1000">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource DSXScrollViewer}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">

            <TextBlock Text="Settings"
                       FontSize="{StaticResource TitleFontSize}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,16" />

            <Expander Style="{StaticResource DSXExpander}" Header="Appearance" IsExpanded="True" Margin="0,0,0,8">
                <StackPanel Margin="0,8,0,0">
                    <Border Style="{StaticResource CardBorder}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Window Effect"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,0,4" />
                            <ComboBox Style="{StaticResource DSXComboBox}"
                                      ItemsSource="{Binding AvailableWindowEffects}"
                                      SelectedItem="{Binding WindowEffect}"
                                      Margin="0,0,0,16" />

                            <TextBlock Text="Language"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,0,4" />
                            <ComboBox Style="{StaticResource DSXComboBox}"
                                      ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding Language}"
                                      Margin="0,0,0,16" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Dark Mode"
                                               Foreground="{StaticResource TextPrimary}" />
                                    <TextBlock Text="Use dark theme for the application interface"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="{StaticResource SmallFontSize}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <controls:ToggleSwitch Grid.Column="1"
                                                       IsChecked="{Binding DarkMode}"
                                                       Width="44" Height="24"
                                                       VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Expander>

            <Expander Style="{StaticResource DSXExpander}" Header="Behaviors" IsExpanded="True" Margin="0,0,0,8">
                <StackPanel Margin="0,8,0,0">
                    <Border Style="{StaticResource CardBorder}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Auto-connect on launch"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                                <controls:ToggleSwitch Grid.Column="1"
                                                       IsChecked="{Binding AutoConnectOnLaunch}"
                                                       Width="44" Height="24" />
                            </Grid>

                            <Separator Style="{StaticResource DSXSeparator}" Margin="0,8" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Start with Windows"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                                <controls:ToggleSwitch Grid.Column="1"
                                                       IsChecked="{Binding StartWithWindows}"
                                                       Width="44" Height="24" />
                            </Grid>

                            <Separator Style="{StaticResource DSXSeparator}" Margin="0,8" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Minimize to tray"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                                <controls:ToggleSwitch Grid.Column="1"
                                                       IsChecked="{Binding MinimizeToTray}"
                                                       Width="44" Height="24" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Backup Manager"
                               FontSize="{StaticResource MediumFontSize}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,16,0,8" />

                    <Border Style="{StaticResource CardBorder}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Backups"
                                           Foreground="{StaticResource TextSecondary}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding CreateBackupCommand}"
                                        Padding="12,6"
                                        FontSize="{StaticResource SmallFontSize}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   Foreground="Black"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0" />
                                        <TextBlock Text="Create Backup" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Backups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SecondaryBackground}"
                                                CornerRadius="{StaticResource SmallCornerRadius}"
                                                Padding="12,8"
                                                Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="&#xE8F1;"
                                                           FontFamily="{StaticResource IconFontFamily}"
                                                           FontSize="14"
                                                           Foreground="{StaticResource NeonPurple}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontWeight="SemiBold" />
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Foreground="{StaticResource TextMuted}"
                                                                   FontSize="{StaticResource SmallFontSize}">
                                                            <TextBlock.Text>
                                                                <Binding Path="CreatedDate" StringFormat="{}{0:g}" />
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock Text=" - "
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   FontSize="{StaticResource SmallFontSize}" />
                                                        <TextBlock Foreground="{StaticResource TextMuted}"
                                                                   FontSize="{StaticResource SmallFontSize}">
                                                            <TextBlock.Text>
                                                                <Binding Path="SizeBytes" StringFormat="{}{0:N0} bytes" />
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Command="{Binding DataContext.RestoreBackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Padding="10,4"
                                                        FontSize="{StaticResource SmallFontSize}"
                                                        Content="Restore"
                                                        Margin="0,0,4,0" />

                                                <Button Grid.Column="3"
                                                        Style="{StaticResource IconButton}"
                                                        Width="28" Height="28"
                                                        ToolTip="Delete backup">
                                                    <TextBlock Text="&#xE711;"
                                                               FontFamily="{StaticResource IconFontFamily}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource ErrorBrush}" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Background="{StaticResource SecondaryBackground}"
                                    CornerRadius="{StaticResource SmallCornerRadius}"
                                    Padding="12,8">
                                <TextBlock Text="No backups found. Create a backup to save your current settings."
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="{StaticResource SmallFontSize}"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Button Style="{StaticResource DangerButton}"
                            Command="{Binding ResetSettingsCommand}"
                            Content="Reset App Settings"
                            Padding="16,8"
                            HorizontalAlignment="Left"
                            Margin="0,16,0,0" />
                </StackPanel>
            </Expander>

            <Expander Style="{StaticResource DSXExpander}" Header="About" Margin="0,0,0,8">
                <StackPanel Margin="0,8,0,0">
                    <Border Style="{StaticResource CardBorder}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="64" Height="64"
                                        Background="{StaticResource SecondaryBackground}"
                                        CornerRadius="{StaticResource LargeCornerRadius}"
                                        Margin="0,0,16,0">
                                    <TextBlock Text="&#xE960;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="28"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="DualSenseX"
                                               FontSize="{StaticResource LargeFontSize}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" />
                                    <TextBlock Foreground="{StaticResource TextSecondary}">
                                        <Run Text="Version " />
                                        <Run Text="{Binding AppVersion, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>

                            <Separator Style="{StaticResource DSXSeparator}" Margin="0,0,0,12" />

                            <TextBlock Text="DSX+ DLC"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="Unlock advanced features including virtual devices, audio haptics, and per-game profiles with the DSX+ DLC."
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Style="{StaticResource SecondaryButton}"
                                        Padding="12,6"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8FD;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="Changelog" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Separator Style="{StaticResource DSXSeparator}" Margin="0,4,0,12" />

                            <TextBlock Text="Support"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />

                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource SecondaryButton}"
                                        Padding="12,6"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8BD;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource NeonPurple}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="Discord" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Expander>

            <Expander Style="{StaticResource DSXExpander}" Header="Backup Server" Margin="0,0,0,8">
                <StackPanel Margin="0,8,0,0">
                    <Border Style="{StaticResource CardBorder}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Regional Override"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,0,4" />
                            <ComboBox Style="{StaticResource DSXComboBox}"
                                      SelectedIndex="0"
                                      Margin="0,0,0,12">
                                <ComboBoxItem Content="Auto-detect" />
                                <ComboBoxItem Content="North America" />
                                <ComboBoxItem Content="Europe" />
                                <ComboBoxItem Content="Asia" />
                                <ComboBoxItem Content="South America" />
                            </ComboBox>

                            <Border Background="{StaticResource SecondaryBackground}"
                                    CornerRadius="{StaticResource SmallCornerRadius}"
                                    Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="14"
                                               Foreground="{StaticResource WarningBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Users in restricted regions may need to select a manual override for backup server connectivity."
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="{StaticResource SmallFontSize}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
