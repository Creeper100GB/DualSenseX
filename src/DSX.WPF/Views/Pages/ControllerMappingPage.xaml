<UserControl x:Class="DSX.WPF.Views.Pages.ControllerMappingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DSX.WPF.Controls"
             xmlns:converters="clr-namespace:DSX.WPF.Converters"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="900">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource DSXScrollViewer}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">

            <!-- Top Bar: Profile + Virtual Device + Emulation -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          Style="{StaticResource DSXComboBox}"
                          ItemsSource="{Binding AvailableProfiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          DisplayMemberPath="Name"
                          Width="180"
                          Margin="0,0,8,0" />

                <ComboBox Grid.Column="1"
                          Style="{StaticResource DSXComboBox}"
                          Width="150"
                          Margin="0,0,8,0"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Xbox 360" />
                    <ComboBoxItem Content="DualShock 4" />
                    <ComboBoxItem Content="DualSense" />
                </ComboBox>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <RadioButton Content="Xbox 360"
                                 GroupName="Emulation"
                                 IsChecked="True"
                                 Foreground="{StaticResource TextSecondary}"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center" />
                    <RadioButton Content="DualShock 4"
                                 GroupName="Emulation"
                                 Foreground="{StaticResource TextSecondary}"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center" />
                    <RadioButton Content="DualSense"
                                 GroupName="Emulation"
                                 Foreground="{StaticResource TextSecondary}"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center" />
                    <RadioButton Content="None"
                                 GroupName="Emulation"
                                 Foreground="{StaticResource TextSecondary}"
                                 VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Controller View -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <controls:ControllerViewControl x:Name="ControllerView"
                                                    Grid.Row="0"
                                                    Width="440" Height="200"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,12" />

                    <Button Grid.Row="1"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearAllButtonSelectionsCommand}"
                            Content="Clear Selection"
                            HorizontalAlignment="Center"
                            Padding="20,6" />
                </Grid>
            </Border>

            <!-- Tabbed Sections -->
            <TabControl Style="{StaticResource DSXTabControl}">
                <TabItem Style="{StaticResource DSXTabItem}" Header="Input Extended">
                    <ScrollViewer Style="{StaticResource DSXScrollViewer}" VerticalScrollBarVisibility="Auto" MaxHeight="600">
                        <StackPanel Margin="0,12,0,0">

                            <!-- Action List -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Action List"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center" />
                                        <Button Style="{StaticResource PrimaryButton}"
                                                Command="{Binding CreateActionCommand}"
                                                Content="Add Action"
                                                HorizontalAlignment="Right"
                                                Padding="16,6" />
                                    </Grid>

                                    <ListView x:Name="ActionListView"
                                              ItemsSource="{Binding ButtonActions}"
                                              SelectedItem="{Binding SelectedButtonAction}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Foreground="{StaticResource TextPrimary}"
                                              MaxHeight="250">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Input" Width="120">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding InputName}"
                                                                       Foreground="{StaticResource TextPrimary}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Press Type" Width="120">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding PressType}"
                                                                       Foreground="{StaticResource TextSecondary}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Action" Width="200">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ActionDescription}"
                                                                       Foreground="{StaticResource TextPrimary}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Width="80">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Style="{StaticResource DangerButton}"
                                                                    Command="{Binding DataContext.DeleteActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    Content="Delete"
                                                                    FontSize="{StaticResource SmallFontSize}"
                                                                    Padding="8,4" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </StackPanel>
                            </Border>

                            <!-- Joystick to Mouse -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Joystick to Mouse"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="0,0,0,12" />

                                    <TextBlock Text="Sensitivity"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Style="{StaticResource DSXSlider}"
                                                Value="{Binding LeftStickMapping.MouseSensitivity}"
                                                Minimum="0" Maximum="100" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding LeftStickMapping.MouseSensitivity, StringFormat='{}{0:F0}'}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Width="40"
                                                   TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Stick to Keyboard -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Stick to Keyboard"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="0,0,0,12" />

                                    <TextBlock Text="Mode"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <RadioButton Content="WASD"
                                                     GroupName="StickKbMode"
                                                     IsChecked="True"
                                                     Foreground="{StaticResource TextSecondary}"
                                                     Margin="0,0,16,0" />
                                        <RadioButton Content="ZQSD"
                                                     GroupName="StickKbMode"
                                                     Foreground="{StaticResource TextSecondary}"
                                                     Margin="0,0,16,0" />
                                        <RadioButton Content="Custom"
                                                     GroupName="StickKbMode"
                                                     Foreground="{StaticResource TextSecondary}" />
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                            <TextBlock Text="Up Key" Foreground="{StaticResource TextMuted}" FontSize="{StaticResource SmallFontSize}" />
                                            <TextBox Style="{StaticResource DSXTextBox}" Text="{Binding LeftStickMapping.UpKey}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                            <TextBlock Text="Down Key" Foreground="{StaticResource TextMuted}" FontSize="{StaticResource SmallFontSize}" />
                                            <TextBox Style="{StaticResource DSXTextBox}" Text="{Binding LeftStickMapping.DownKey}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Left Key" Foreground="{StaticResource TextMuted}" FontSize="{StaticResource SmallFontSize}" />
                                            <TextBox Style="{StaticResource DSXTextBox}" Text="{Binding LeftStickMapping.LeftKey}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Right Key" Foreground="{StaticResource TextMuted}" FontSize="{StaticResource SmallFontSize}" />
                                            <TextBox Style="{StaticResource DSXTextBox}" Text="{Binding LeftStickMapping.RightKey}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Stick to Buttons -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <TextBlock Text="Stick to Buttons"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" />
                            </Border>

                            <!-- Motion to Keyboard -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Motion to Keyboard"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="0,0,0,12" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Up Key" Foreground="{StaticResource TextMuted}" FontSize="{StaticResource SmallFontSize}" />
                                            <TextBox Style="{StaticResource DSXTextBox}" Text="{Binding MotionMapping.UpKey}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Down Key" Foreground="{StaticResource TextMuted}" FontSize="{StaticResource SmallFontSize}" />
                                            <TextBox Style="{StaticResource DSXTextBox}" Text="{Binding MotionMapping.DownKey}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Motion to Buttons -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <TextBlock Text="Motion to Buttons"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" />
                            </Border>

                            <!-- Touchpad Gestures -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Touchpad Gestures"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="0,0,0,12" />

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Enabled"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                                        <controls:ToggleSwitch Grid.Column="1"
                                                               IsChecked="{Binding TouchpadGestureConfig.Enabled}"
                                                               Width="44" Height="24"
                                                               HorizontalAlignment="Right" />
                                    </Grid>

                                    <TextBlock Text="Left Motor Haptics Intensity"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,4,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Style="{StaticResource DSXSlider}"
                                                Value="{Binding TouchpadGestureConfig.LeftMotorHapticsIntensity}"
                                                Minimum="0" Maximum="100" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TouchpadGestureConfig.LeftMotorHapticsIntensity}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Width="30" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>

                                    <TextBlock Text="Right Motor Haptics Intensity"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,4,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Style="{StaticResource DSXSlider}"
                                                Value="{Binding TouchpadGestureConfig.RightMotorHapticsIntensity}"
                                                Minimum="0" Maximum="100" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TouchpadGestureConfig.RightMotorHapticsIntensity}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Width="30" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Style="{StaticResource DSXTabItem}" Header="Deadzones">
                    <ScrollViewer Style="{StaticResource DSXScrollViewer}" VerticalScrollBarVisibility="Auto" MaxHeight="600">
                        <StackPanel Margin="0,12,0,0">

                            <!-- Left Stick Deadzone -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Left Stick"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="0,0,0,12" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <controls:CircularDeadzoneVisualizer Grid.Column="0"
                                                                            Width="140" Height="140"
                                                                            InnerDeadzone="{Binding DeadzoneConfig.LeftStickInner}"
                                                                            OuterDeadzone="{Binding DeadzoneConfig.LeftStickOuter}"
                                                                            Margin="0,0,20,0" />

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Inner Deadzone"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,0,0,4" />
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Slider Style="{StaticResource DSXSlider}"
                                                        Value="{Binding DeadzoneConfig.LeftStickInner}"
                                                        Minimum="0" Maximum="100" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DeadzoneConfig.LeftStickInner, StringFormat='{}{0:F0}%'}"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           Width="50" TextAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0" />
                                            </Grid>

                                            <TextBlock Text="Outer Deadzone"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,0,0,4" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Slider Style="{StaticResource DSXSlider}"
                                                        Value="{Binding DeadzoneConfig.LeftStickOuter}"
                                                        Minimum="0" Maximum="100" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DeadzoneConfig.LeftStickOuter, StringFormat='{}{0:F0}%'}"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           Width="50" TextAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Right Stick Deadzone -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Right Stick"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="0,0,0,12" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <controls:CircularDeadzoneVisualizer Grid.Column="0"
                                                                            Width="140" Height="140"
                                                                            InnerDeadzone="{Binding DeadzoneConfig.RightStickInner}"
                                                                            OuterDeadzone="{Binding DeadzoneConfig.RightStickOuter}"
                                                                            Margin="0,0,20,0" />

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Inner Deadzone"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,0,0,4" />
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Slider Style="{StaticResource DSXSlider}"
                                                        Value="{Binding DeadzoneConfig.RightStickInner}"
                                                        Minimum="0" Maximum="100" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DeadzoneConfig.RightStickInner, StringFormat='{}{0:F0}%'}"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           Width="50" TextAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0" />
                                            </Grid>

                                            <TextBlock Text="Outer Deadzone"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,0,0,4" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Slider Style="{StaticResource DSXSlider}"
                                                        Value="{Binding DeadzoneConfig.RightStickOuter}"
                                                        Minimum="0" Maximum="100" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DeadzoneConfig.RightStickOuter, StringFormat='{}{0:F0}%'}"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           Width="50" TextAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Trigger Deadzones -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Trigger Deadzones"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center" />
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                            <TextBlock Text="Apply same to both"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />
                                            <controls:ToggleSwitch IsChecked="{Binding DeadzoneConfig.ApplySameTriggerSettings}"
                                                                   Width="44" Height="24" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Left Trigger"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,0,0,4" />
                                            <Slider Style="{StaticResource DSXSlider}"
                                                    Value="{Binding DeadzoneConfig.LeftTriggerDeadzone}"
                                                    Minimum="0" Maximum="100" />
                                            <ProgressBar Value="{Binding DeadzoneConfig.LeftTriggerDeadzone}"
                                                         Style="{StaticResource DSXProgressBar}"
                                                         Height="4"
                                                         Margin="0,8,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="Right Trigger"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,0,0,4" />
                                            <Slider Style="{StaticResource DSXSlider}"
                                                    Value="{Binding DeadzoneConfig.RightTriggerDeadzone}"
                                                    Minimum="0" Maximum="100" />
                                            <ProgressBar Value="{Binding DeadzoneConfig.RightTriggerDeadzone}"
                                                         Style="{StaticResource DSXProgressBar}"
                                                         Height="4"
                                                         Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Curve Editor -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Response Curve"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="0,0,0,12" />

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <RadioButton Content="Linear"
                                                     GroupName="CurveType"
                                                     IsChecked="True"
                                                     Foreground="{StaticResource TextSecondary}"
                                                     Margin="0,0,16,0" />
                                        <RadioButton Content="Aggressive"
                                                     GroupName="CurveType"
                                                     Foreground="{StaticResource TextSecondary}"
                                                     Margin="0,0,16,0" />
                                        <RadioButton Content="Relaxed"
                                                     GroupName="CurveType"
                                                     Foreground="{StaticResource TextSecondary}"
                                                     Margin="0,0,16,0" />
                                        <RadioButton Content="Custom"
                                                     GroupName="CurveType"
                                                     Foreground="{StaticResource TextSecondary}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Style="{StaticResource DSXTabItem}" Header="Vibration">
                    <ScrollViewer Style="{StaticResource DSXScrollViewer}" VerticalScrollBarVisibility="Auto" MaxHeight="600">
                        <StackPanel Margin="0,12,0,0">

                            <!-- Time-based Vibration -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Time-based"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="0,0,0,12" />

                                    <TextBlock Text="Left Motor Intensity"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,0,0,4" />
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Style="{StaticResource DSXSlider}"
                                                Value="{Binding LargeMotorIntensity}"
                                                Minimum="0" Maximum="100" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding LargeMotorIntensity, StringFormat='{}{0:F0}'}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Width="30" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>

                                    <TextBlock Text="Right Motor Intensity"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,0,0,4" />
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Style="{StaticResource DSXSlider}"
                                                Value="{Binding SmallMotorIntensity}"
                                                Minimum="0" Maximum="100" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SmallMotorIntensity, StringFormat='{}{0:F0}'}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Width="30" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>

                                    <Button Style="{StaticResource PrimaryButton}"
                                            Command="{Binding TestRumbleCommand}"
                                            Content="Test"
                                            HorizontalAlignment="Left"
                                            Padding="20,6" />
                                </StackPanel>
                            </Border>

                            <!-- Interval-based Vibration -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Interval-based"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="0,0,0,12" />

                                    <TextBlock Text="Left Motor Intensity"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,0,0,4" />
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Style="{StaticResource DSXSlider}"
                                                Minimum="0" Maximum="100" />
                                        <TextBlock Grid.Column="1"
                                                   Text="0"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Width="30" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>

                                    <TextBlock Text="Right Motor Intensity"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,0,0,4" />
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Style="{StaticResource DSXSlider}"
                                                Minimum="0" Maximum="100" />
                                        <TextBlock Grid.Column="1"
                                                   Text="0"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Width="30" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>

                                    <TextBlock Text="Interval (ms)"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,0,0,4" />
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Style="{StaticResource DSXSlider}"
                                                Minimum="10" Maximum="1000" />
                                        <TextBlock Grid.Column="1"
                                                   Text="100"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Width="40" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>

                                    <TextBlock Text="Duration (s)"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Style="{StaticResource DSXSlider}"
                                                Minimum="1" Maximum="1000" />
                                        <TextBlock Grid.Column="1"
                                                   Text="1"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Width="40" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
