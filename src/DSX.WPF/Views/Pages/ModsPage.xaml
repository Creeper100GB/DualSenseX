<UserControl x:Class="DSX.WPF.Views.Pages.ModsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DSX.WPF.Controls"
             xmlns:converters="clr-namespace:DSX.WPF.Converters"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="900">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource DSXScrollViewer}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Mods"
                           FontSize="{StaticResource TitleFontSize}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshModsCommand}"
                            Padding="12,6"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding OpenModRepositoryCommand}"
                            Padding="16,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Foreground="Black"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Add Mod" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <TextBlock Text="Supported Games"
                       FontSize="{StaticResource LargeFontSize}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,12" />

            <ItemsControl ItemsSource="{Binding AvailableMods}" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="44" Height="44"
                                        Background="{StaticResource SecondaryBackground}"
                                        CornerRadius="{StaticResource DefaultCornerRadius}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="&#xE7FC;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="16"
                                               Foreground="{StaticResource NeonPurple}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding GameName}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" />
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="{StaticResource SmallFontSize}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0" />
                                </StackPanel>

                                <Border Grid.Column="2"
                                        Background="{StaticResource SecondaryBackground}"
                                        CornerRadius="{StaticResource RoundCornerRadius}"
                                        Padding="8,3"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                    <TextBlock FontSize="{StaticResource SmallFontSize}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource NeonBlue}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionMethod}" Value="Textfile">
                                                        <Setter Property="Foreground" Value="{StaticResource NeonPurple}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <TextBlock.Text>
                                            <Binding Path="ConnectionMethod" FallbackValue="UDP" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>

                                <Button Grid.Column="3"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="12,6"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="Download"
                                               FontSize="{StaticResource SmallFontSize}" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="UDP Port Configuration"
                       FontSize="{StaticResource LargeFontSize}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,8,0,12" />

            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Port Number"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding UdpPort, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DSXTextBox}"
                             Margin="0,0,12,0" />
                    <Border Grid.Column="2"
                            Background="{StaticResource SecondaryBackground}"
                            CornerRadius="{StaticResource RoundCornerRadius}"
                            Padding="8,3"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="10"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0" />
                            <TextBlock Text="Auto-saved"
                                       FontSize="{StaticResource SmallFontSize}"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Border>
                    <Button Grid.Column="3"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveUdpPortCommand}"
                            Content="Apply"
                            Padding="16,6"
                            HorizontalAlignment="Left" />
                </Grid>
            </Border>

            <TextBlock Text="Active Mods"
                       FontSize="{StaticResource LargeFontSize}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,8,0,12" />

            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,16">
                <ItemsControl ItemsSource="{Binding AvailableMods}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SecondaryBackground}"
                                    CornerRadius="{StaticResource SmallCornerRadius}"
                                    Padding="12,8"
                                    Margin="0,0,0,4"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0"
                                             Width="8" Height="8"
                                             Fill="{StaticResource AccentBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="4" ShadowDepth="0" Opacity="0.5" />
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding GameName}"
                                               Foreground="{StaticResource TextPrimary}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource DangerButton}"
                                            Command="{Binding DataContext.RemoveModCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Content="Remove"
                                            Padding="10,4"
                                            FontSize="{StaticResource SmallFontSize}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <TextBlock Text="Mod API for Developers"
                       FontSize="{StaticResource LargeFontSize}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,8,0,12" />

            <Border Style="{StaticResource CardBorder}" Padding="20">
                <StackPanel>
                    <Expander Style="{StaticResource DSXExpander}" Header="Textfile Method" Margin="0,0,0,8">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Write instructions to a text file that DSX reads periodically. Place the file in the DSX directory with a specific format."
                                       Foreground="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <Border Background="#0D0D0D"
                                    CornerRadius="{StaticResource SmallCornerRadius}"
                                    Padding="12">
                                <TextBlock FontFamily="Consolas"
                                           FontSize="{StaticResource SmallFontSize}"
                                           Foreground="{StaticResource NeonGreen}"
                                           TextWrapping="Wrap"
                                           Text="{}{&quot;instructions&quot;: [{&quot;type&quot;: 1, &quot;parameters&quot;: [0, 255, 0]}]}" />
                            </Border>
                        </StackPanel>
                    </Expander>

                    <Expander Style="{StaticResource DSXExpander}" Header="UDP Method" Margin="0,0,0,8">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Send JSON packets via UDP to the configured port. This method supports real-time communication with minimal latency."
                                       Foreground="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <Border Background="#0D0D0D"
                                    CornerRadius="{StaticResource SmallCornerRadius}"
                                    Padding="12">
                                <TextBlock FontFamily="Consolas"
                                           FontSize="{StaticResource SmallFontSize}"
                                           Foreground="{StaticResource NeonBlue}"
                                           TextWrapping="Wrap"><![CDATA[{
  "instructions": [
    {
      "type": 1,
      "parameters": [0, 255, 0]
    },
    {
      "type": 2,
      "parameters": [128]
    }
  ]
}]]></TextBlock>
                            </Border>
                        </StackPanel>
                    </Expander>

                    <Border Background="{StaticResource SecondaryBackground}"
                            CornerRadius="{StaticResource SmallCornerRadius}"
                            Padding="12,8"
                            Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="14"
                                       Foreground="{StaticResource NeonPurple}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="Default UDP port: 6969. Ensure your firewall allows incoming connections on the configured port."
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
