<UserControl x:Class="DSX.WPF.Views.Pages.MyControllersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DSX.WPF.Controls"
             xmlns:converters="clr-namespace:DSX.WPF.Converters"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="900">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <converters:BatteryToColorConverter x:Key="BatteryToColorConverter" />
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource DSXScrollViewer}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">

            <!-- Device Information Card -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock Text="Device Information"
                               FontSize="{StaticResource LargeFontSize}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="120" Height="120"
                                Background="#1500D4AA"
                                CornerRadius="12"
                                Margin="0,0,20,0"
                                VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/DSX;component/Resources/Images/controller_dualsense.png"
                                   Width="100" Height="100"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>

                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,8">
                                <TextBlock Text="Controller Name"
                                           Style="{StaticResource DSXMutedTextBlock}" />
                                <TextBlock Text="{Binding ControllerName}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource MediumFontSize}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,8">
                                <TextBlock Text="Connection Type"
                                           Style="{StaticResource DSXMutedTextBlock}" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="14"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xE85E;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Bluetooth">
                                                        <Setter Property="Text" Value="&#xE702;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ConnectionIcon}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                <TextBlock Text="Battery"
                                           Style="{StaticResource DSXMutedTextBlock}" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Foreground="{StaticResource TextPrimary}"
                                               FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <Binding Path="BatteryPercent" StringFormat="{}{0:F0}%" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Text=" (Charging)"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="{StaticResource SmallFontSize}"
                                               Visibility="{Binding IsCharging, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                                <ProgressBar Value="{Binding BatteryPercent}"
                                             Style="{StaticResource DSXProgressBar}"
                                             Height="6"
                                             Margin="0,4,0,0">
                                    <ProgressBar.Foreground>
                                        <Binding Path="BatteryPercent">
                                            <Binding.Converter>
                                                <converters:BatteryToColorConverter />
                                            </Binding.Converter>
                                        </Binding>
                                    </ProgressBar.Foreground>
                                </ProgressBar>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,8">
                                <TextBlock Text="Firmware Version"
                                           Style="{StaticResource DSXMutedTextBlock}" />
                                <TextBlock Text="{Binding FirmwareVersion}"
                                           Foreground="{StaticResource TextPrimary}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,12,8">
                                <TextBlock Text="Build Date"
                                           Style="{StaticResource DSXMutedTextBlock}" />
                                <TextBlock Text="{Binding BuildDate}"
                                           Foreground="{StaticResource TextPrimary}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Text="MAC Address"
                                           Style="{StaticResource DSXMutedTextBlock}" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding MacAddress}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center" />
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding CopyMacAddressCommand}"
                                            Width="28" Height="28"
                                            ToolTip="Copy MAC Address"
                                            Margin="8,0,0,0">
                                        <TextBlock Text="&#xE8C8;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0"
                                        Visibility="{Binding ConnectionType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Bluetooth}">
                                <TextBlock Text="Bluetooth RSSI"
                                           Style="{StaticResource DSXMutedTextBlock}" />
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Grid.Column="0"
                                                 Value="{Binding BTRSSI}"
                                                 Minimum="-100" Maximum="0"
                                                 Style="{StaticResource DSXProgressBar}"
                                                 Height="6" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding BTRSSI, StringFormat='{}{0} dBm'}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="{StaticResource SmallFontSize}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Device Features Grid -->
                    <TextBlock Text="Supported Features"
                               Style="{StaticResource DSXMutedTextBlock}"
                               Margin="0,8,0,8" />
                    <ItemsControl ItemsSource="{Binding DeviceFeatures}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SecondaryBackground}"
                                        CornerRadius="{StaticResource SmallCornerRadius}"
                                        Padding="8,6"
                                        Margin="2">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE73E;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Supported}" Value="False">
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                            <Setter Property="Text" Value="&#xE711;" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="{StaticResource SmallFontSize}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Profile Slot System -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Profile Slots"
                                   FontSize="{StaticResource LargeFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center" />
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding CycleSlotCommand}"
                                Content="Cycle"
                                HorizontalAlignment="Right"
                                Padding="16,6" />
                    </Grid>

                    <UniformGrid Columns="4">
                        <ItemsControl ItemsSource="{Binding ProfileSlots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="SlotBorder"
                                            Background="{StaticResource SecondaryBackground}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource DefaultCornerRadius}"
                                            Padding="12"
                                            Margin="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#00D4AA" BlurRadius="8" ShadowDepth="0" Opacity="0.3" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding SlotIndex, StringFormat='Slot {0}'}"
                                                       FontSize="{StaticResource SmallFontSize}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding ProfileName}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding ActivateKey}"
                                                       FontSize="{StaticResource SmallFontSize}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- General Settings -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock Text="General Settings"
                               FontSize="{StaticResource LargeFontSize}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Auto-connect on launch"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding AutoConnectOnLaunch}"
                                               Width="44" Height="24" />
                    </Grid>

                    <Separator Style="{StaticResource DSXSeparator}" Margin="0,8" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Kill Steam on launch"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding KillSteamOnLaunch}"
                                               Width="44" Height="24" />
                    </Grid>

                    <Separator Style="{StaticResource DSXSeparator}" Margin="0,8" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Start with Windows"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding StartWithWindows}"
                                               Width="44" Height="24" />
                    </Grid>

                    <Separator Style="{StaticResource DSXSeparator}" Margin="0,8" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Minimize to tray on close"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding MinimizeToTray}"
                                               Width="44" Height="24" />
                    </Grid>

                    <Separator Style="{StaticResource DSXSeparator}" Margin="0,8" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Toggle Microphone Mute via DualSense"
                                       Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                            <TextBlock Text="Default: ON"
                                       Style="{StaticResource DSXMutedTextBlock}" Margin="0,2,0,0" />
                        </StackPanel>
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding ToggleMicMute}"
                                               Width="44" Height="24" />
                    </Grid>

                    <Separator Style="{StaticResource DSXSeparator}" Margin="0,8" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Motion Controls"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding MotionEnabled}"
                                               Width="44" Height="24" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Notifications -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock Text="Notifications"
                               FontSize="{StaticResource LargeFontSize}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Controller Connected / Disconnected"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding NotifyConnection}"
                                               Width="44" Height="24" />
                    </Grid>

                    <Separator Style="{StaticResource DSXSeparator}" Margin="0,8" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Profile Switched"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding NotifyProfileSwitch}"
                                               Width="44" Height="24" />
                    </Grid>

                    <Separator Style="{StaticResource DSXSeparator}" Margin="0,8" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Battery Low"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding NotifyBatteryLow}"
                                               Width="44" Height="24" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- DualSense Edge Settings -->
            <Border Style="{StaticResource CardBorder}"
                    Padding="20"
                    Visibility="{Binding IsDualSenseEdge, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="DualSense Edge Settings"
                               FontSize="{StaticResource LargeFontSize}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,16" />

                    <TextBlock Text="On-board Profiles"
                               Style="{StaticResource DSXMutedTextBlock}"
                               Margin="0,0,0,8" />

                    <ItemsControl ItemsSource="{Binding EdgeProfiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SecondaryBackground}"
                                        CornerRadius="{StaticResource SmallCornerRadius}"
                                        Padding="12,8"
                                        Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Index, StringFormat='Profile {0}'}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,0,12,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="{StaticResource SmallFontSize}"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <Binding Path="LastModified" StringFormat="{}{0:g}" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
