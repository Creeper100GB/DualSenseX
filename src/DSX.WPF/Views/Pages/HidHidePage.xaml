<UserControl x:Class="DSX.WPF.Views.Pages.HidHidePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DSX.WPF.Controls"
             xmlns:converters="clr-namespace:DSX.WPF.Converters"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="900">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource DSXScrollViewer}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">

            <TextBlock Text="HidHide"
                       FontSize="{StaticResource TitleFontSize}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,16" />

            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="48" Height="48"
                            CornerRadius="{StaticResource DefaultCornerRadius}"
                            Margin="0,0,16,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1AFF3333" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDriverInstalled}" Value="True">
                                        <Setter Property="Background" Value="#1A00D4AA" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE711;" />
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDriverInstalled}" Value="True">
                                            <Setter Property="Text" Value="&#xE73E;" />
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Driver Status"
                                   FontSize="{StaticResource MediumFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="{StaticResource SmallFontSize}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="The HidHide driver is not installed on this system." />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDriverInstalled}" Value="True">
                                            <Setter Property="Text" Value="The HidHide driver is installed and ready to use." />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                        <Border Background="{StaticResource SecondaryBackground}"
                                CornerRadius="{StaticResource RoundCornerRadius}"
                                Padding="10,4"
                                Margin="0,0,12,0">
                            <TextBlock FontWeight="SemiBold" FontSize="{StaticResource SmallFontSize}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding DriverStatusText}" />
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDriverInstalled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding RefreshDriverStatusCommand}"
                                Content="Refresh"
                                Padding="12,6" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Let DSX Control HidHide"
                                       FontSize="{StaticResource MediumFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="When enabled, DSX will automatically manage controller hiding based on the active application."
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding LetDSXControl}"
                                               Width="44" Height="24"
                                               VerticalAlignment="Center" />
                    </Grid>

                    <Separator Style="{StaticResource DSXSeparator}" Margin="0,4,0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Persistent Device Hiding"
                                       FontSize="{StaticResource MediumFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="Keep controllers hidden even when DSX is not running. Requires HidHide driver."
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <controls:ToggleSwitch Grid.Column="1"
                                               IsChecked="{Binding PersistentHiding}"
                                               Width="44" Height="24"
                                               VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="Whitelisted Applications"
                       FontSize="{StaticResource LargeFontSize}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,8" />

            <TextBlock Text="Applications that can see hidden controllers"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="{StaticResource SmallFontSize}"
                       Margin="0,0,0,8" />

            <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Applications"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RefreshDriverStatusCommand}"
                                    Padding="10,4"
                                    Margin="0,0,8,0"
                                    FontSize="{StaticResource SmallFontSize}">
                                <TextBlock Text="&#xE72C;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           Margin="0,0,4,0" />
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddToWhitelistCommand}"
                                    Padding="10,4"
                                    FontSize="{StaticResource SmallFontSize}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Foreground="Black"
                                               Margin="0,0,4,0" />
                                    <TextBlock Text="Add" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding WhitelistedApps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SecondaryBackground}"
                                        CornerRadius="{StaticResource SmallCornerRadius}"
                                        Padding="12,8"
                                        Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="&#xE8E5;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="14"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="{StaticResource SmallFontSize}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Consolas" />
                                        <Button Grid.Column="2"
                                                Style="{StaticResource IconButton}"
                                                Width="28" Height="28"
                                                ToolTip="Remove">
                                            <TextBlock Text="&#xE711;"
                                                       FontFamily="{StaticResource IconFontFamily}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource ErrorBrush}" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="{StaticResource SecondaryBackground}"
                            CornerRadius="{StaticResource SmallCornerRadius}"
                            Padding="12,8"
                            Visibility="{Binding WhitelistedApps.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=Invert}">
                        <TextBlock Text="No whitelisted applications. Add an application to allow it to see hidden controllers."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="{StaticResource SmallFontSize}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="Hidden Devices"
                       FontSize="{StaticResource LargeFontSize}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,8,0,8" />

            <TextBlock Text="Controllers currently hidden from games and applications"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="{StaticResource SmallFontSize}"
                       Margin="0,0,0,8" />

            <Border Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Devices"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" />
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding RefreshDriverStatusCommand}"
                                Padding="10,4"
                                FontSize="{StaticResource SmallFontSize}">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,4,0" />
                        </Button>
                    </Grid>

                    <Border Background="{StaticResource SecondaryBackground}"
                            CornerRadius="{StaticResource SmallCornerRadius}"
                            Padding="12,8"
                            Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0"
                                     Width="8" Height="8"
                                     Fill="{StaticResource ErrorBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,10,0" />
                            <TextBlock Grid.Column="1"
                                       Text="DualSense Wireless Controller"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="HID\\VID_054C&amp;PID_0CE6"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="{StaticResource SmallFontSize}"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <Button Grid.Column="3"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,4"
                                    FontSize="{StaticResource SmallFontSize}"
                                    Content="Unhide" />
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource SecondaryBackground}"
                            CornerRadius="{StaticResource SmallCornerRadius}"
                            Padding="12,8">
                        <TextBlock Text="No hidden devices. Enable HidHide and configure hiding to see devices here."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="{StaticResource SmallFontSize}"
                                   HorizontalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
