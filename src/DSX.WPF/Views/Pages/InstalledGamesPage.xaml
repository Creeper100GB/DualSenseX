<UserControl x:Class="DSX.WPF.Views.Pages.InstalledGamesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DSX.WPF.Controls"
             xmlns:converters="clr-namespace:DSX.WPF.Converters"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="800">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Installed Games"
                           FontSize="{StaticResource TitleFontSize}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ScanGamesCommand}"
                        Padding="16,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE895;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="Scan Games" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource InputBackground}"
                        BorderBrush="{StaticResource InputBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource DefaultCornerRadius}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#xE721;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="14"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,8,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DSXTextBox}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0,8,10,8"
                                 Margin="0"
                                 ToolTip="Search installed games" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <ListView ItemsSource="{Binding FilteredGames}"
                          SelectedItem="{Binding SelectedGame}"
                          Style="{StaticResource DSXListView}"
                          BorderThickness="0"
                          Background="Transparent"
                          Margin="-2">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DSXListViewItem}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="36" Height="36"
                                        Background="{StaticResource SecondaryBackground}"
                                        CornerRadius="{StaticResource SmallCornerRadius}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="&#xE7FC;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="14"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <Border Grid.Column="2"
                                        Background="{StaticResource SecondaryBackground}"
                                        CornerRadius="{StaticResource RoundCornerRadius}"
                                        Padding="8,3"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Platform}"
                                               FontSize="{StaticResource SmallFontSize}"
                                               Foreground="{StaticResource NeonBlue}"
                                               FontWeight="SemiBold" />
                                </Border>

                                <Border Grid.Column="3"
                                        Background="{StaticResource SecondaryBackground}"
                                        CornerRadius="{StaticResource RoundCornerRadius}"
                                        Padding="8,3"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding AssignedProfileName, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock FontSize="{StaticResource SmallFontSize}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AssignedProfileName}" Value="">
                                                        <Setter Property="Text" Value="No Profile" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <TextBlock.Text>
                                            <Binding Path="AssignedProfileName" TargetNullValue="No Profile" FallbackValue="No Profile" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="16">
            <StackPanel>
                <TextBlock Text="Profile Assignment"
                           FontSize="{StaticResource LargeFontSize}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           Margin="0,0,0,16" />

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="48" Height="48"
                            Background="{StaticResource SecondaryBackground}"
                            CornerRadius="{StaticResource DefaultCornerRadius}"
                            Margin="0,0,12,0">
                        <TextBlock Text="&#xE7FC;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="18"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedGame.Name}"
                               Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold"
                               FontSize="{StaticResource MediumFontSize}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <TextBlock Text="Assigned Profile"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,4" />
                <ComboBox Style="{StaticResource DSXComboBox}"
                          Text="{Binding AssignedProfileId}"
                          Margin="0,0,0,16"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Select a profile..." />
                </ComboBox>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Reset on game close"
                                   Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Text="Return to previous profile when the game exits"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="{StaticResource SmallFontSize}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                    <controls:ToggleSwitch Grid.Column="1"
                                           IsChecked="{Binding ResetProfileOnGameClose}"
                                           Width="44" Height="24"
                                           VerticalAlignment="Center" />
                </Grid>

                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding AssignProfileCommand}"
                        Content="Assign Profile"
                        Padding="16,8"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8" />

                <Button Style="{StaticResource DangerButton}"
                        Command="{Binding RemoveProfileCommand}"
                        Content="Remove Assignment"
                        Padding="16,8"
                        HorizontalAlignment="Stretch" />

                <Separator Style="{StaticResource DSXSeparator}" Margin="0,16" />

                <Border Background="{StaticResource SecondaryBackground}"
                        CornerRadius="{StaticResource SmallCornerRadius}"
                        Padding="12,8">
                    <StackPanel>
                        <TextBlock Text="&#xE946;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="14"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="Select a game from the list to assign or manage its controller profile."
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="{StaticResource SmallFontSize}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
