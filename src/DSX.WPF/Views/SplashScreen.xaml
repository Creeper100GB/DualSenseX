<Window x:Class="DSX.WPF.Views.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DualSenseX"
        Width="480" Height="280"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        Loaded="OnLoaded">

    <Border Background="{StaticResource PrimaryBackground}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Padding="40"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.5" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Margin="0,8,0,16">
                <Border Width="52" Height="52"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="12"
                        Margin="0,0,16,0">
                    <Border.Effect>
                        <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="16" ShadowDepth="0" Opacity="0.4" />
                    </Border.Effect>
                    <TextBlock Text="D"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="Black"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DualSenseX"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="DualSense Controller Tool"
                               FontSize="12"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- Version -->
            <TextBlock Grid.Row="1"
                       Text="v3.1.5.3"
                       FontSize="11"
                       Foreground="{StaticResource TextMuted}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />

            <!-- Loading Bar -->
            <Grid Grid.Row="2" VerticalAlignment="Center">
                <Border Height="3"
                        Background="{StaticResource SliderTrackBrush}"
                        CornerRadius="2" />
                <Border x:Name="ProgressBar"
                        Height="3"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="2"
                        HorizontalAlignment="Left"
                        Width="0">
                    <Border.Effect>
                        <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.6" />
                    </Border.Effect>
                </Border>
            </Grid>

            <!-- Loading Text -->
            <TextBlock Grid.Row="3"
                       x:Name="LoadingText"
                       Text="Loading DSX..."
                       FontSize="12"
                       Foreground="{StaticResource TextMuted}"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0" />

            <!-- Animated Dots -->
            <TextBlock Grid.Row="4"
                       x:Name="DotsText"
                       Text=""
                       FontSize="16"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
        </Grid>
    </Border>
</Window>
