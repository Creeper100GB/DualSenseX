<Window x:Class="DSX.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DSX.WPF"
        xmlns:nav="clr-namespace:DSX.WPF.Navigation"
        xmlns:converters="clr-namespace:DSX.WPF.Converters"
        mc:Ignorable="d"
        Title="DualSenseX"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        d:DesignWidth="1200" d:DesignHeight="800"
        Loaded="OnLoaded"
        Closing="OnClosing"
        SourceInitialized="OnSourceInitialized"
        StateChanged="OnStateChanged">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <converters:BatteryToColorConverter x:Key="BatteryToColorConverter" />
        <converters:DoubleToPercentageConverter x:Key="DoubleToPercentageConverter" />

        <QuadraticEase x:Key="FadeEase" EasingMode="EaseOut" />

        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.25"
                             EasingFunction="{StaticResource FadeEase}" />
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInStoryboard}" />
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="WindowBorder"
            Background="{StaticResource PrimaryBackground}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True">

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" x:Name="TitleBar"
                  Background="{StaticResource SidebarBackground}"
                  MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- App Icon + Title -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <Border Width="24" Height="24"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="5"
                            Margin="0,0,10,0">
                        <TextBlock Text="&#xE96A;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Foreground="Black"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="DSX"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" />
                    <Border Background="#1A1A1A"
                            CornerRadius="4"
                            Padding="8,2"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="v3.1.5.3"
                                   FontSize="10"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <!-- Center drag area -->
                <Rectangle Grid.Column="1" Fill="Transparent" />

                <!-- Window Controls -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="MinimizeButton"
                            Click="OnMinimizeClick"
                            Style="{StaticResource IconButton}"
                            Width="46" Height="34"
                            ToolTip="Minimize">
                        <TextBlock Text="&#xE921;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Click="OnMaximizeClick"
                            Style="{StaticResource IconButton}"
                            Width="46" Height="34"
                            ToolTip="Maximize">
                        <TextBlock x:Name="MaximizeIcon"
                                   Text="&#xE922;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Button x:Name="CloseButton"
                            Click="OnCloseClick"
                            Width="46" Height="34"
                            ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="RootBorder"
                                        Background="Transparent"
                                        SnapsToDevicePixels="True">
                                    <TextBlock Text="&#xE711;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="RootBorder" Property="Background" Value="#E81123" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="RootBorder" Property="Background" Value="#C50F1F" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" MinWidth="200" MaxWidth="300" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <nav:NavigationView x:Name="SidebarNav"
                                    Grid.Column="0"
                                    CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                                    IsControllerConnected="{Binding IsControllerConnected}"
                                    BatteryPercentage="{Binding ActiveController.BatteryPercentage}"
                                    NavigationChanged="OnNavigationChanged" />

                <!-- Sidebar Right Border -->
                <Border Grid.Column="1"
                        Width="1"
                        Background="{StaticResource BorderBrush}"
                        SnapsToDevicePixels="True" />

                <!-- Page Content -->
                <Grid Grid.Column="2" x:Name="ContentArea">
                    <ContentControl x:Name="PageContent" Margin="20" />

                    <!-- Page Transition Overlay -->
                    <Grid x:Name="TransitionOverlay"
                          Background="{StaticResource PrimaryBackground}"
                          Opacity="0"
                          IsHitTestVisible="False" />
                </Grid>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2"
                    Background="{StaticResource SidebarBackground}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,5"
                    CornerRadius="0,0,8,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Connection Status -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="StatusBarConnectionDot"
                                 Width="8" Height="8"
                                 Fill="{StaticResource ErrorBrush}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0" />
                        <TextBlock x:Name="StatusBarConnectionText"
                                   Text="Disconnected"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Active Profile -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="20,0,0,0">
                        <TextBlock Text="&#xE77B;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <TextBlock x:Name="StatusBarProfileText"
                                   Text="No Profile"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Spacer -->

                    <!-- Battery -->
                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0"
                                Visibility="{Binding IsControllerConnected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="&#xE85A;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <TextBlock x:Name="StatusBarBatteryText"
                                   Text="--"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Version -->
                    <TextBlock Grid.Column="4"
                               Text="v3.1.5.3"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
